# Public Convex deployment URL used by browser and server-rendered pages.
# Local development typically uses the URL created by `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Required for server-side internal Convex calls in cloud/production environments.
# Keep this private (never expose via NEXT_PUBLIC_*).
# Local development can fall back to Convex local state under `~/.convex/`.
CONVEX_DEPLOY_KEY=

# JWT signing secret for session cookies.
AUTH_JWT_SECRET=replace-with-a-long-random-secret

# Supabase connection for seed scripts (optional — only needed for `supabase/seed/` scripts).
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Drizzle/Postgres connection strings (optional — only needed for DB features).
# DATABASE_URL: Transaction pooler for app queries.
# DIRECT_URL: Direct connection for drizzle-kit and seed scripts.
# DATABASE_URL=
# DIRECT_URL=

# OpenAI API key for teacher error-analysis AI (optional — AI summary disabled if unset).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=https://api.openai.com/v1

# AI Interpretation Pipeline (optional — disabled by default).
# AI_INTERPRETATION_ENABLED=true
# AI_INTERPRETATION_PROVIDER=openai
# AI_INTERPRETATION_API_KEY=
# AI_INTERPRETATION_MAX_TOKENS=500
# AI_INTERPRETATION_TIMEOUT_MS=5000

# Demo user passwords (optional — defaults to 'Demo1234!' if unset).
# DEMO_TEACHER_PASSWORD=
# DEMO_STUDENT_PASSWORD=
# DEMO_ADMIN_PASSWORD=

# API key for test-only routes (optional — if set, test routes require matching x-test-api-key header).
# TEST_API_KEY=
