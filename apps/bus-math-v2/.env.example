# Public Convex deployment URL used by browser and server-rendered pages.
# Local development typically uses the URL created by `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Required for server-side internal Convex calls in cloud/production environments.
# Keep this private (never expose via NEXT_PUBLIC_*).
# Local development can fall back to Convex local state under `~/.convex/`.
CONVEX_DEPLOY_KEY=

# JWT signing secret for session cookies.
AUTH_JWT_SECRET=replace-with-a-long-random-secret
