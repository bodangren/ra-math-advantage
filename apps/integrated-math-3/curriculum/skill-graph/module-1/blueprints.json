      "workedExampleSpec": {
        "prompt": "Find the average rate of change of f(x) = x^2 + 3x - 1 on the interval [1, 4].",
        "givens": [
          "f(x) = x^2 + 3x - 1",
          "Interval: [1, 4]"
        ],
        "target": {
          "rate": "8"
        },
        "steps": [
          {
            "description": "Evaluate f at x = 1",
            "expression": "f(1) = 1 + 3 - 1 = 3",
            "result": "f(1) = 3"
          },
          {
            "description": "Evaluate f at x = 4",
            "expression": "f(4) = 16 + 12 - 1 = 27",
            "result": "f(4) = 27"
          },
          {
            "description": "Compute average rate of change",
            "expression": "(f(4) - f(1)) / (4 - 1) = (27 - 3) / 3 = 8",
            "result": "8"
          }
        ],
        "explanation": "The average rate of change is the slope of the secant line between two points on the graph."
      },
      "guidedPracticeSpec": {
        "scaffoldedPrompt": "Find the average rate of change of f(x) = x^2 - 2x + 5 on [2, 6].",
        "stepPrompts": [
          "Evaluate f(2)",
          "Evaluate f(6)",
          "Apply the average rate of change formula"
        ],
        "hints": [
          "Substitute x = 2 into f(x)",
          "Substitute x = 6 into f(x)",
          "Average rate of change = (f(b) - f(a)) / (b - a)"
        ],
        "checksPerStep": [
