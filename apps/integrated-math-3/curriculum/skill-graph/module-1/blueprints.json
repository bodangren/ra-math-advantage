          "direction": "upward"
        },
        "steps": [
          {
            "description": "Identify the quadratic coefficient",
            "expression": "a = 1, b = 0, c = -4",
            "explanation": "The coefficient a = 1 > 0, so the parabola opens upward."
          },
          {
            "description": "Find the vertex",
            "expression": "h = -b/(2a) = 0, k = f(0) = -4",
            "result": "Vertex: (0, -4)"
          },
          {
            "description": "Find the y-intercept",
            "expression": "f(0) = -4",
            "result": "Y-intercept: (0, -4)"
          },
          {
            "description": "Find the x-intercepts",
            "expression": "0 = x^2 - 4, x = \u00b12",
            "result": "X-intercepts: (-2, 0) and (2, 0)"
          }
        ],
        "explanation": "The function f(x) = x^2 - 4 is a parabola opening upward with vertex at (0, -4), passing through the origin translated 4 units down."
      },
      "guidedPracticeSpec": {
        "scaffoldedPrompt": "Graph f(x) = x^2 - 2x - 3 by finding key features step by step.",
