## Example 3 ‚Äî Write as a Single Logarithm

### Step 1: Apply Logarithm Properties

[3 \ln 3 - \ln 9 = \ln 3^3 - \ln 9 = \ln 27 - \ln 9 = \ln \frac{27}{9} = \ln 3]

[4 \ln 16 - \ln 256 = \ln 16^4 - \ln 256 = \ln 65536 - \ln 256 = \ln \frac{65536}{256} = \ln 256]

[2 \ln x + 2 \ln 4 = \ln x^2 + \ln 16 = \ln (16x^2)]

[3 \ln 4 + 3 \ln 3 = \ln 4^3 + \ln 3^3 = \ln 64 + \ln 27 = \ln 1728]

[\ln 125 - 2 \ln 5 = \ln 125 - \ln 25 = \ln \frac{125}{25} = \ln 5]

[3 \ln 10 + 2 \ln 100 = \ln 10^3 + \ln 100^2 = \ln 1000 + \ln 10000 = \ln 10,000,000]

[4 \ln \frac{1}{3} - 6 \ln \frac{1}{9} = \ln \left(\frac{1}{3}\right)^4 - \ln \left(\frac{1}{9}\right)^6 = \ln \frac{1}{81} - \ln \frac{1}{531441} = \ln (531441/81) = \ln 6561]

[7 \ln \frac{1}{2} + 5 \ln 2 = \ln \left(\frac{1}{2}\right)^7 + \ln 2^5 = \ln \frac{1}{128} + \ln 32 = \ln \frac{32}{128} = \ln \frac{1}{4} = -\ln 4]

[8 \ln x - 4 \ln 5 = \ln x^8 - \ln 625 = \ln \frac{x^8}{625}]

