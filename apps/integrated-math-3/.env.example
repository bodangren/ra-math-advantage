# Public Convex deployment URL used by browser and server-rendered pages.
# Local development typically uses the URL created by `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# JWT signing secret for session cookies.
AUTH_JWT_SECRET=replace-with-a-long-random-secret

# OpenRouter API key for AI tutoring chatbot (optional — chatbot returns 503 if unset).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default OpenRouter model.
# OPENROUTER_MODEL=openrouter/free

# Optional: override the default OpenRouter API base URL.
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
